# Enable rewrite engine
RewriteEngine On

# 1. Redirect from URL.html to clean URL (external redirect)
# Prevents duplicate URLs if someone types the .html manually
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Map clean URL to URL.html internally (so server processes it)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]
